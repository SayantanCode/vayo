# Copy to .env and fill in — never commit the real .env (see docs/05-security.md §7)

# Your own MongoDB connection string — Vayo never hosts this data itself.
VAYO_MONGO_URI=mongodb://localhost:27017/myapp_vayo

# Port for @vayo/server (REST API + Socket.IO + static UI)
VAYO_SERVER_PORT=4100

# Port for apps/demo-app (the sample Express app used to prove M1)
PORT=4000
