{
  "name": "@vayo/openapi-compiler",
  "version": "0.1.1-beta.1",
  "license": "MIT",
  "description": "Compiles resolved endpoints into a valid OpenAPI 3.1 document with x-vayo-* extensions. Validates via @apidevtools/swagger-parser before ever returning a document.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SayantanCode/vayo.git",
    "directory": "packages/openapi-compiler"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@vayo/types": "workspace:*",
    "@vayo/schema-engine": "workspace:*",
    "@apidevtools/swagger-parser": "^10.1.0"
  }
}
