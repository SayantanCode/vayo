    "seed-versions": "tsx src/seed-versions.ts",
    "reset-docs-data": "tsx src/reset-docs-data.ts",
    "vayo-server": "tsx watch src/vayo-server.ts",
    "verify-realtime": "tsx src/verify-realtime.ts",
    "build": "tsc -b"
