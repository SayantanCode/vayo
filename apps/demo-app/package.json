    "@vayo/openapi-compiler": "workspace:*",
    "@vayo/server": "workspace:*",
    "express": "^4.19.0",
    "bcrypt": "^6.0.0",
    "mongodb": "^6.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/bcrypt": "^6.0.0",
    "tsx": "^4.16.2",
    "socket.io-client": "^4.7.5"
