  "private": true,
  "description": "A small Express app used to prove the M1 capture pipeline against real traffic (docs/09-roadmap.md M1 done-when).",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "scan": "tsx src/scan.ts",
    "export": "tsx src/export.ts",
